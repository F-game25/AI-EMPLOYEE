# AI Employee — Environment Variables (from openclaw-2)
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Security (REQUIRED) ────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=

# ── AI API Keys (Optional — only if using external AI providers) ───────────────
# Leave empty to use the local Ollama model instead.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Per-Agent Model Routing ────────────────────────────────────────────────────
# Model used for sales/persuasion agents (lead-hunter, email-ninja, web-sales)
# OPENAI_SALES_MODEL=gpt-4o
# Model used for analytics/research agents (data-analyst, intel-agent)
# CLAUDE_MODEL=claude-opus-4-5
# Model used for general/local agents (all others)
# OLLAMA_MODEL=llama3.2

# ── Dashboard Ports (Optional — defaults shown) ────────────────────────────────
# PROBLEM_SOLVER_UI_PORT=8787
# DASHBOARD_PORT=3000

# ── Rate Limiting (Optional — defaults shown) ──────────────────────────────────
# RATE_LIMIT_PER_MINUTE=60
# MAX_SESSIONS_PER_USER=3

# ── Additional API Keys (Optional) ────────────────────────────────────────────
# ALPHA_INSIDER_KEY=
# TAVILY_KEY=
# NEWS_API_KEY=
# TELEGRAM_BOT_TOKEN=
# DISCORD_WEBHOOK_URL=
# ELEVEN_LABS_KEY=

# ── SMTP Email (Optional — for email_sender tool) ─────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=your_app_password
# SMTP_USE_SSL=false

# ── Twilio WhatsApp (Optional — for whatsapp tool) ────────────────────────────
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Agent Memory (Optional — defaults shown) ──────────────────────────────────
# MEMORY_MAX_TURNS=50

# ── Feedback Loop (Optional — defaults shown) ─────────────────────────────────
# FEEDBACK_LOOP_POLL_INTERVAL=30
# FEEDBACK_MIN_SENDS=5
# FEEDBACK_LOW_REPLY_RATE=0.10
# FEEDBACK_MAX_EVENTS=1000

# ── Task Orchestrator (Optional — defaults shown) ─────────────────────────────
# TASK_ORCHESTRATOR_MAX_PARALLEL=10
# TASK_ORCHESTRATOR_PEER_REVIEW=true
# TASK_ORCHESTRATOR_TIMEOUT=600
