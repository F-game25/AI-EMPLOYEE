# AI Employee — Environment Variables
# Copy this file to ~/.ai-employee/.env and fill in your values.
# NEVER commit .env to version control.

# ── Security (REQUIRED) ────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=

# Set to 1 to require JWT auth for all state-modifying endpoints when the
# dashboard is exposed beyond localhost (e.g. reverse-proxy / VPS deployment).
# REQUIRE_AUTH=0

# ── AI API Keys (Optional — only if using external AI providers) ───────────────
# Leave empty to use the local Ollama model instead.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── NVIDIA NIM (Free-Tier Cloud AI — Recommended) ─────────────────────────────
# Get your free API key at: https://build.nvidia.com
# NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NIM_API_KEY=           # NVIDIA NIM API key
NIM_ENDPOINT=          # e.g. https://integrate.api.nvidia.com/v1
NIM_MODEL=             # e.g. meta/llama-3.1-70b-instruct

# Override default NIM models (all optional):
# NIM_REASONING_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1
# NIM_CODING_MODEL=qwen/qwen2.5-coder-32b-instruct
# NIM_BULK_MODEL=meta/llama-3.1-8b-instruct
# NIM_EMBED_MODEL=nvidia/nv-embed-v2
# NIM_RERANK_MODEL=nvidia/nv-rerankqa-mistral-4b-v3
# NIM_MAX_TOKENS=2048
# NIM_TIMEOUT=60

# --- Remote Compute (optional) ---
REMOTE_COMPUTE_HOST=   # SSH host for offload
REMOTE_COMPUTE_USER=   # SSH user
REMOTE_COMPUTE_KEY=    # Path to SSH private key

# ── Lead Intelligence Agents (Optional) ───────────────────────────────────────
# LEAD_SCORING_DEFAULT_ICP=B2B SaaS company 10-200 employees seeking AI automation
# LEAD_HUNTER_MAX_LEADS=20
# DEAL_MIN_SCORE=0.6
# OUTREACH_SENDER_NAME=Alex
# OUTREACH_SENDER_COMPANY=AI Employee
# OUTREACH_VALUE_PROP=We help businesses automate lead generation with AI
# VECTOR_MEMORY_DIR=~/.ai-employee/state/vector_memory
# VECTOR_SIMILARITY_THRESHOLD=0.92

# ── Per-Agent Model Routing (Optional) ────────────────────────────────────────
# OPENAI_MODEL_SALES=gpt-4o
# OPENAI_MODEL_CREATIVE=gpt-4o
# CLAUDE_MODEL=claude-opus-4-6

# ── Ollama (Local AI — free & private) ────────────────────────────────────────
# Install from https://ollama.com and run: ollama pull llama3.2
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=llama3.2
# OLLAMA_TIMEOUT=60
# LOCAL_AI_FIRST=1                       # always try Ollama before cloud providers (default: 1)
# OLLAMA_BATCH_MAX_WORKERS=4             # parallel workers for query_ai_batch() (default: 4)

# ── Google Gemma (Free local open-source AI — sits alongside Ollama) ──────────
# Gemma runs FREE & LOCALLY via Ollama (recommended):
#   ollama pull gemma4       # or: ollama pull gemma3  for the previous version
# Alternatively, use the Google AI Studio free-tier cloud API:
#   Get a free key at https://aistudio.google.com/app/apikey
#
# GEMMA_MODEL=gemma4                     # Ollama model tag  (default: gemma4, or use gemma3)
# GEMMA_VIA_OLLAMA=1                     # 1=use local Ollama, 0=Google AI Studio (default: 1)
# GOOGLE_API_KEY=                        # Google AI Studio key (for cloud backend)
# GEMMA_CLOUD_MODEL=gemma-3-27b-it       # model via Google AI Studio (default: gemma-3-27b-it)
# GEMMA_TIMEOUT=120                      # request timeout in seconds (default: 120)
# GEMMA_AGENT_PORT=8793                  # Gemma agent web UI port (default: 8793)

# ── Sub-agent provider inheritance ────────────────────────────────────────────
# Force ALL sub-agents to use the same provider as the selected main AI.
# Valid values: ollama | gemma | nvidia_nim | anthropic | openai
# Leave empty (default) to use automatic per-task routing.
# ACTIVE_AI_PROVIDER=

# ── Two-Layer Routing ─────────────────────────────────────────────────────────
# LOCAL_AI_FIRST=1 (default) — always try free/local providers FIRST:
#   Layer 1: Ollama (local) → NVIDIA NIM (free-tier)
#   Layer 2: Paid cloud APIs (Anthropic → OpenAI) — only if Layer 1 fails
# Set to 0 to use preferred-provider-first routing (original behaviour).
# LOCAL_AI_FIRST=1

# ── Agent Memory (Optional — persistent per-lead conversation history) ─────────
# MEMORY_MAX_CONVERSATION=50
# MEMORY_MAX_FACTS=100

# ── Feedback Loop (Optional — automatic prompt optimisation) ──────────────────
# FEEDBACK_POLL_INTERVAL=30
# FEEDBACK_TOP_N=5

# ── Task Orchestrator (Optional) ──────────────────────────────────────────────
# TASK_ORCHESTRATOR_MAX_PARALLEL=10    # run up to 10 agents concurrently
# TASK_ORCHESTRATOR_PEER_REVIEW=true   # agents review each other's outputs

# ── Dashboard Ports (Optional — defaults shown) ────────────────────────────────
# PROBLEM_SOLVER_UI_PORT=8787
# DASHBOARD_PORT=3000

# ── Logging (Optional) ────────────────────────────────────────────────────────
# LOG_LEVEL=WARNING

# ── Rate Limiting (Optional — defaults shown) ──────────────────────────────────
# RATE_LIMIT_PER_MINUTE=60
# MAX_SESSIONS_PER_USER=3

# ── Discord Bot (Optional) ────────────────────────────────────────────────────
# Create a bot at https://discord.com/developers/applications, enable
# "Message Content Intent", invite it to your server, then paste the token below.
# DISCORD_BOT_TOKEN=
# DISCORD_COMMAND_PREFIX=!
# DISCORD_WEBHOOK_URL=

# ── WhatsApp Integration (Optional) ───────────────────────────────────────────
# Option A: Twilio WhatsApp (recommended)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Option B: Meta WhatsApp Cloud API
# WHATSAPP_TOKEN=
# WHATSAPP_PHONE_ID=
# WHATSAPP_DRY_RUN=false
# Inbound webhook port (for reply detection):
# WHATSAPP_WEBHOOK_PORT=8790
# WHATSAPP_WEBHOOK_HOST=0.0.0.0

# ── Email Integration (Optional) ──────────────────────────────────────────────
# SMTP (Gmail, Outlook, Mailgun SMTP, etc.)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@example.com
# SMTP_PASS=your-app-password
# SMTP_FROM=you@example.com
# SMTP_USE_TLS=true
# Option B: SendGrid (better deliverability for cold outreach)
# SENDGRID_API_KEY=
# SENDGRID_FROM=you@example.com
# EMAIL_DRY_RUN=false
# EMAIL_REPLY_TO=

# ── Additional API Keys (Optional) ────────────────────────────────────────────
# ALPHA_INSIDER_KEY=
# TAVILY_API_KEY=                       # Best AI web search quality
# SERP_API_KEY=                         # Google search via SerpAPI
# NEWS_API_KEY=
# TELEGRAM_BOT_TOKEN=

# ── Agent Memory (Optional — defaults shown) ──────────────────────────────────
# MEMORY_MAX_CONVERSATION=50            # max conversation turns per entity
# MEMORY_MAX_FACTS=100                  # max facts per entity

# ── Feedback Loop (Optional — defaults shown) ─────────────────────────────────
# FEEDBACK_LOOP_POLL_INTERVAL=30        # seconds between feedback scans
# FEEDBACK_MIN_SENDS=5                  # minimum sends before scoring
# FEEDBACK_LOW_REPLY_RATE=0.10
# FEEDBACK_MAX_EVENTS=1000
# FEEDBACK_TOP_N=5

# ── Task Orchestrator (Optional — defaults shown) ─────────────────────────────
# TASK_ORCHESTRATOR_MAX_PARALLEL=10     # run up to 10 agents concurrently
# TASK_ORCHESTRATOR_PEER_REVIEW=true    # agents review each other's outputs
# TASK_ORCHESTRATOR_TIMEOUT=600

# ── Obsidian Memory Base (Optional) ───────────────────────────────────────────
# OBSIDIAN_VAULT_PATH=/home/yourusername/Obsidian/Vault
# OBSIDIAN_POLL_INTERVAL=5
# OBSIDIAN_MAX_CONTEXT_NOTES=5
# OBSIDIAN_LANGUAGE=en

# ── Wave Field LLM (Optional — O(n log n) long-context routing) ───────────────
# When enabled, requests exceeding WAVEFIELD_ROUTE_MIN_TOKENS are routed to
# an Ollama-hosted Wave Field compatible model instead of the primary backend.
#
# WAVEFIELD_ENABLED=1
# WAVEFIELD_MODEL=qwen2.5-coder:7b          # any Ollama-pulled model
# WAVEFIELD_ROLLOUT_MODE=shadow             # shadow | canary | default | off
#   shadow  — fires wave field in background, returns primary response
#   canary  — routes WAVEFIELD_CANARY_PERCENT% of eligible traffic to wave field
#   default — routes all eligible long-context requests to wave field
# WAVEFIELD_ROUTE_MIN_TOKENS=8000           # token threshold for "long" tier
# WAVEFIELD_ALLOW_FALLBACK=1               # fall back to primary on wave field error
# WAVEFIELD_CANARY_PERCENT=10              # % of traffic for canary mode

# ── Neural Brain (LangGraph + Mem0 + Neo4j cognitive stack) ───────────────────
# Runs LangGraph reasoning workflows over Mem0 long-term memory and a Neo4j
# knowledge graph. Local-only: uses Ollama LLMs + sentence-transformers
# embeddings. No cloud APIs required.
#
# Bring up infra:  docker compose -f docker-compose.neural-brain.yml up -d neo4j
NEURAL_BRAIN_ENABLED=true
NEURAL_BRAIN_HOOK_PIPELINE=false       # let unified_pipeline.py call NeuralMemoryManager too
NEURAL_BRAIN_PROXY_LEGACY=false        # write-through to legacy memory_router
NEURAL_BRAIN_LCM_ENABLED=false         # Latent Consistency image gen (needs ComfyUI/A1111)
NEURAL_BRAIN_SAM_ENABLED=false         # Segment Anything (needs segment_anything pkg)
# NEURAL_BRAIN_LCM_BACKEND_URL=http://localhost:7860/sdapi/v1
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neuralbrain
NEURAL_BRAIN_CHROMA_DIR=state/neural_brain/chroma
NEURAL_BRAIN_MEM0_DIR=state/neural_brain/mem0
NEURAL_BRAIN_TRACES_DIR=state/neural_brain/traces
NEURAL_BRAIN_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
NEURAL_BRAIN_OLLAMA_HOST=http://localhost:11434
NEURAL_BRAIN_LLM_MODEL=llama3.1:8b      # primary LLM for Mem0 + reasoning
NEURAL_BRAIN_SLM_MODEL=phi3:mini        # small/fast model for low-latency intents
NEURAL_BRAIN_MOE_MODEL=mixtral:8x7b-instruct-q4_K_M
NEURAL_BRAIN_VLM_MODEL=llava:7b
NEURAL_BRAIN_NODE_BRIDGE_URL=http://localhost:8787/internal/events

# ── Privacy + Local-First Mode ────────────────────────────────────────────────
# OFFLINE   — zero external calls, all AI runs locally, no telemetry
# HYBRID    — external APIs allowed (via keys above), no telemetry (DEFAULT)
# CONNECTED — external APIs + opt-in anonymised telemetry export
PRIVACY_MODE=HYBRID

# Admin credentials (used to bootstrap the first ADMIN user on startup)
# Password must be ≥12 chars with uppercase, digit, and special char
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
ADMIN_EMAIL=admin@nexus.local

# ── Telemetry (only active when PRIVACY_MODE=CONNECTED + TELEMETRY_ENABLED=1) ─
# What is sent: error types, latency stats, event counts — NEVER user content
# TELEMETRY_ENABLED=0
# TELEMETRY_ENDPOINT=https://telemetry.your-update-server.com
# TELEMETRY_BUNDLE_INTERVAL_S=86400     # 24h default

# ── Updates (only active when PRIVACY_MODE=HYBRID or CONNECTED) ───────────────
# AUTO_UPDATE=0                          # 0=check only, 1=auto-apply
# UPDATE_ENDPOINT=https://updates.your-server.com
# UPDATE_CHECK_INTERVAL_S=21600          # 6h default

# ── Key Rotation ──────────────────────────────────────────────────────────────
# KEY_ROTATION_INTERVAL_S=600            # 10 min default
# KEY_GRACE_PERIOD_S=120                 # 2 min grace for in-flight tokens
