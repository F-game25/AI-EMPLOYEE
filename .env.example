# AI Employee — Environment Variables (from openclaw-2)
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Security (REQUIRED) ────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=

# ── AI API Keys (Optional — only if using external AI providers) ───────────────
# Leave empty to use the local Ollama model instead.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Dashboard Ports (Optional — defaults shown) ────────────────────────────────
# PROBLEM_SOLVER_UI_PORT=8787
# DASHBOARD_PORT=3000

# ── Rate Limiting (Optional — defaults shown) ──────────────────────────────────
# RATE_LIMIT_PER_MINUTE=60
# MAX_SESSIONS_PER_USER=3

# ── Additional API Keys (Optional) ────────────────────────────────────────────
# ALPHA_INSIDER_KEY=
# TAVILY_KEY=
# NEWS_API_KEY=
# TELEGRAM_BOT_TOKEN=
# DISCORD_WEBHOOK_URL=
# SMTP_HOST=
# SMTP_USER=
# SMTP_PASS=
# ELEVEN_LABS_KEY=
