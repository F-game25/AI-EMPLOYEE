# How often the researcher runs a full simulation cycle (seconds)
MIROFISH_RESEARCH_INTERVAL=300

# Number of swarm agents per simulation (higher = more accurate, more CPU)
MIROFISH_AGENTS=500

# Number of interaction rounds per simulation
MIROFISH_ROUNDS=20

# Number of independent scenario runs per market (for confidence intervals)
MIROFISH_SCENARIOS=5

# Comma-separated Polymarket market IDs to research.
# If empty, the researcher will use any market IDs found in mirofish_signals.json.
RESEARCH_MARKETS=
