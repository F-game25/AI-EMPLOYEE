{
  "wizard": {
    "lastRunCommand": "install",
    "lastRunMode": "local"
  },
  "agents": {
    "defaults": {
      "workspace": "AI_HOME_PLACEHOLDER/workspace"
    }
  },
  "tools": {
    "profile": "coding"
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "session": {
    "dmScope": "per-channel-peer"
  },
  "gateway": {
    "port": 8787,
    "mode": "local",
    "bind": "loopback",
    "auth": {
      "mode": "token",
      "token": "TOKEN_PLACEHOLDER"
    },
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    }
  },
  "channels": {
    "whatsapp": {
      "dmPolicy": "allowlist",
      "allowFrom": [
        "PHONE_PLACEHOLDER"
      ],
      "groups": {
        "*": {
          "requireMention": true
        }
      },
      "mediaMaxMb": 50,
      "sendReadReceipts": true
    }
  },
  "skills": {
    "install": {
      "nodeManager": "npm"
    }
  }
}
