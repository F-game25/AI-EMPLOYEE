# PAPER mode by default. Set LIVE_TRADING=true only when ready.
LIVE_TRADING=false

# Kill switch - set to true to halt all trading immediately
KILL_SWITCH=false

# Strategy / risk settings
PM_POLL_SECONDS=60
EDGE_THRESHOLD=0.07
MAX_POSITION_USD=25

# Market allowlist (comma-separated market IDs). Empty = no markets traded.
ALLOW_MARKETS=

# ── MiroFish swarm intelligence (inline simulation) ───────────────────────────
# Enable/disable the inline MiroFish swarm predictor
MIROFISH_ENABLED=true
# Number of swarm agents per inline simulation (lower = faster, higher = more accurate)
MIROFISH_AGENTS=200
# Number of interaction rounds per inline simulation
MIROFISH_ROUNDS=15

# ── Alpha Insider strategy signals ────────────────────────────────────────────
# Set your Alpha Insider API key for strategy ratings (https://alphainsider.com)
ALPHA_INSIDER_ENABLED=true
# ALPHA_INSIDER_API_KEY=your-key-here
ALPHA_INSIDER_TIMEOUT=10

# ── Strategy selector (auto-optimization) ─────────────────────────────────────
# Automatically tests parameter configurations and selects the best performers
STRATEGY_SELECTOR_ENABLED=true
# Minimum trades required before scoring a strategy configuration
STRATEGY_MIN_TRADES=5

# TODO: add your Polymarket auth variables here once you choose a client.
# POLYMARKET_API_KEY=
# POLYMARKET_PRIVATE_KEY=
