# task-orchestrator configuration
# Edit these values as needed

# Poll interval (seconds)
TASK_ORCHESTRATOR_POLL_INTERVAL=5

# Long-context routing layer:
# - short requests stay on DEFAULT model path
# - long requests can use Wave Field model path when enabled
WAVEFIELD_ENABLED=0
WAVEFIELD_ROUTE_MIN_TOKENS=8000
WAVEFIELD_ALLOW_FALLBACK=1
WAVEFIELD_ROLLOUT_MODE=default
WAVEFIELD_CANARY_PERCENT=10
# Optional explicit long-context model override
# WAVEFIELD_MODEL=your-wavefield-model-name
