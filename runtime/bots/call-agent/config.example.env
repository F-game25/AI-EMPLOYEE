# AI Call Agent — Configuration
# Copy to ~/.ai-employee/config/call-agent.env (or add to ~/.ai-employee/.env)

# ── Server ──────────────────────────────────────────────────────────────────
CALL_AGENT_PORT=8791
CALL_AGENT_HOST=127.0.0.1

# Public base URL Twilio will POST to (required for Twilio callbacks).
# Use ngrok for local testing: ngrok http 8791
# CALL_AGENT_BASE_URL=https://<your-ngrok-or-domain>.ngrok.io

# ── Twilio ───────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
# TWILIO_PHONE_NUMBER=+31612345678

# Number to transfer to when fallback is triggered (optional):
# CALL_TRANSFER_NUMBER=+31612345678

# ── Agent Persona ────────────────────────────────────────────────────────────
CALL_AGENT_NAME=Alex
CALL_DEALER_NAME=AutoPrime
CALL_LANGUAGE=nl-NL
CALL_VOICE_NAME=Polly.Lotte

# Fallback message spoken when LLM is unavailable or too slow:
# CALL_FALLBACK_RESPONSE=Sorry, een moment — ik verbind je door met een collega.

# ── Speech Recognition ───────────────────────────────────────────────────────
# "api"   — use OpenAI Whisper API (requires OPENAI_API_KEY)
# "local" — use local openai-whisper library (pip install openai-whisper)
# Default: "api" when OPENAI_API_KEY is set, otherwise "local"
# WHISPER_MODE=api
# WHISPER_MODEL=base

# ── Text-to-Speech ───────────────────────────────────────────────────────────
# "voxtral" — Voxtral / Mistral AI TTS (requires VOXTRAL_API_KEY)
# "openai"  — OpenAI TTS tts-1 (requires OPENAI_API_KEY)
# "twilio"  — use Twilio built-in <Say> (no extra API needed)
# Default: "voxtral" > "openai" > "twilio" (first available)
# TTS_BACKEND=twilio

# Public base URL where TTS audio files are served (required for voxtral/openai TTS):
# TTS_BASE_URL=https://<your-domain>.ngrok.io

# Voxtral (Mistral AI) TTS:
# VOXTRAL_API_KEY=your_mistral_api_key
# VOXTRAL_MODEL=voxtral-mini
# VOXTRAL_VOICE=alloy

# OpenAI TTS fallback:
# OPENAI_TTS_VOICE=alloy

# ── LLM Engine ───────────────────────────────────────────────────────────────
# Max seconds to wait for LLM response before returning fallback:
CALL_LLM_TIMEOUT_SECONDS=4

# Speech gather timeout (seconds of silence before Twilio submits):
CALL_GATHER_TIMEOUT=5
# CALL_SPEECH_TIMEOUT=auto

# ── Logging ──────────────────────────────────────────────────────────────────
# LOG_LEVEL=INFO

# ── Session Management ───────────────────────────────────────────────────────
# How long (seconds) before an idle call session is automatically expired:
# CALL_SESSION_TTL_SECONDS=3600
