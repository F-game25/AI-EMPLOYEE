      { id: 's2', user_email: p.email || 'admin@system', ip: '10.0.0.5',        created_at: new Date(now - 7200000).toISOString(), expires_at: new Date(now + 86400000).toISOString() },
      { id: 's3', user_email: p.email || 'admin@system', ip: '192.168.1.20',    created_at: new Date(now - 86400000).toISOString(), expires_at: new Date(now + 3600000).toISOString() },
