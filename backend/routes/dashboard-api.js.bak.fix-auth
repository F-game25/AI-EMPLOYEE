    const role   = { id: `role_${Date.now()}`, name, description, builtin: false, created_at: new Date().toISOString() }
    custom.push(role)
    writeJSON(file, custom)
    res.json({ ok: true, role })
  })

  r.delete('/roles/:id', requireAuth, (req, res) => {
    if (BUILTIN_ROLES.some(r => r.id === req.params.id)) return res.status(400).json({ error: 'cannot delete builtin role' })
    const file   = path.join(STATE_DIR, 'roles.json')
