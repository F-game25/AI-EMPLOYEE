  // ── OLLAMA ADMIN ────────────────────────────────────────────────────────────
  const ollamaAdmin = require('../services/ollama_admin')

  r.get('/ollama/models', requireAuth, async (_req, res) => {
    try { res.json({ models: await ollamaAdmin.listLocalModels() }) }
    catch (e) { res.status(502).json({ error: e.message, models: [] }) }
  })

  r.get('/ollama/models/:name', requireAuth, async (req, res) => {
    try { res.json(await ollamaAdmin.showModel(req.params.name)) }
    catch (e) { res.status(502).json({ error: e.message }) }
  })

  r.delete('/ollama/models/:name', requireAuth, async (req, res) => {
    try { res.json(await ollamaAdmin.deleteModel(req.params.name)) }
    catch (e) { res.status(502).json({ error: e.message }) }
  })

  r.post('/ollama/pull', requireAuth, async (req, res) => {
    const { name } = req.body || {}
    if (!name) return res.status(400).json({ error: 'name required' })
    res.setHeader('Content-Type', 'text/event-stream')
    res.setHeader('Cache-Control', 'no-cache')
    res.setHeader('Connection', 'keep-alive')
    try {
      for await (const evt of ollamaAdmin.pullModelStream(name)) {
        res.write(`data: ${JSON.stringify(evt)}\n\n`)
      }
      res.write(`data: ${JSON.stringify({ status: 'success', complete: true })}\n\n`)
      res.end()
    } catch (e) {
      res.write(`data: ${JSON.stringify({ status: 'error', error: e.message })}\n\n`)
      res.end()
    }
  })

  // ── MAIN MODEL SWITCHER ─────────────────────────────────────────────────────
  // Persists to model-routing.json (read by runtime/core/llm_router.py at LLMClient init)
  const ROUTING_FILE = path.join(STATE_DIR, 'model-routing.json')

  r.get('/settings/main-model', requireAuth, (_req, res) => {
    const cfg = readJSON(ROUTING_FILE, {})
    res.json(cfg._default || { provider: 'anthropic', model: 'claude-sonnet-4-6' })
  })

  r.put('/settings/main-model', requireAuth, (req, res) => {
    const { provider, model } = req.body || {}
    if (!provider || !model) return res.status(400).json({ error: 'provider and model required' })
    const cfg = readJSON(ROUTING_FILE, {})
    cfg._default = { provider, model }
    writeJSON(ROUTING_FILE, cfg)
    res.json({ ok: true, default: cfg._default })
  })

  // ── SUBSYSTEMS ROUTING ──────────────────────────────────────────────────────
  const SUBSYSTEMS_FILE = path.resolve(__dirname, '..', '..', 'runtime', 'config', 'subsystems.json')

  r.get('/settings/subsystems', requireAuth, (_req, res) => {
    const subsystems = readJSON(SUBSYSTEMS_FILE, [])
    const routing = readJSON(ROUTING_FILE, {})
    const subRouting = routing.subsystems || {}
    res.json({
      subsystems: (Array.isArray(subsystems) ? subsystems : []).map(s => ({
        ...s,
        current: subRouting[s.id] || null,
      })),
    })
  })

  r.put('/settings/subsystem-routing/:id', requireAuth, (req, res) => {
    const { id } = req.params
    const { provider, model } = req.body || {}
    if (!provider || !model) return res.status(400).json({ error: 'provider and model required' })
    const cfg = readJSON(ROUTING_FILE, {})
    if (!cfg.subsystems) cfg.subsystems = {}
    cfg.subsystems[id] = { provider, model }
    writeJSON(ROUTING_FILE, cfg)
    res.json({ ok: true, subsystem: id, route: cfg.subsystems[id] })
  })

  // ── MemoryAdapter (Chroma + Qdrant) proxy → Python backend ──
  // Helper: forwards Authorization header so Python's auth middleware accepts it.
  function _authHeaders(req, extra = {}) {
    return {
      ...extra,
      ...(req.headers.authorization ? { 'authorization': req.headers.authorization } : {}),
    }
  }

  r.get('/memory/adapter/status', requireAuth, async (req, res) => {
    try {
      const r1 = await fetch(`${PYTHON_BACKEND}/api/memory/adapter/status`, { headers: _authHeaders(req) })
      res.status(r1.status).json(await r1.json())
    } catch (e) {
      res.status(503).json({ error: 'python backend unavailable', detail: e.message })
    }
  })

  r.post('/memory/adapter/search', requireAuth, async (req, res) => {
    try {
      const r1 = await fetch(`${PYTHON_BACKEND}/api/memory/adapter/search`, {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify(req.body || {}),
      })
      res.status(r1.status).json(await r1.json())
    } catch (e) {
      res.status(503).json({ error: 'python backend unavailable', detail: e.message })
    }
  })

  r.post('/memory/adapter/add', requireAuth, async (req, res) => {
    try {
      const r1 = await fetch(`${PYTHON_BACKEND}/api/memory/adapter/add`, {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify(req.body || {}),
      })
      res.status(r1.status).json(await r1.json())
    } catch (e) {
      res.status(503).json({ error: 'python backend unavailable', detail: e.message })
    }
  })

  // ── Verification + pending review queue (proxied to Python) ────────────
  r.post('/memory/verify', requireAuth, async (req, res) => {
    try {
      const r1 = await fetch(`${PYTHON_BACKEND}/api/memory/verify`, {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify(req.body || {}),
      })
      res.status(r1.status).json(await r1.json())
    } catch (e) {
      res.status(503).json({ error: 'python backend unavailable', detail: e.message })
    }
  })

  r.get('/memory/pending-review', requireAuth, async (req, res) => {
    try {
      const qs = new URLSearchParams(req.query).toString()
      const r1 = await fetch(`${PYTHON_BACKEND}/api/memory/pending-review${qs ? '?' + qs : ''}`)
      res.status(r1.status).json(await r1.json())
    } catch (e) {
      res.status(503).json({ error: 'python backend unavailable', detail: e.message })
    }
  })

  r.get('/memory/pending-review/:id', requireAuth, async (req, res) => {
    try {
      const r1 = await fetch(`${PYTHON_BACKEND}/api/memory/pending-review/${encodeURIComponent(req.params.id)}`)
      res.status(r1.status).json(await r1.json())
    } catch (e) {
      res.status(503).json({ error: 'python backend unavailable', detail: e.message })
    }
  })

  r.post('/memory/pending-review/:id/approve', requireAuth, async (req, res) => {
    try {
      const r1 = await fetch(`${PYTHON_BACKEND}/api/memory/pending-review/${encodeURIComponent(req.params.id)}/approve`, { method: 'POST' })
      res.status(r1.status).json(await r1.json())
    } catch (e) {
      res.status(503).json({ error: 'python backend unavailable', detail: e.message })
    }
  })

  r.post('/memory/pending-review/:id/reject', requireAuth, async (req, res) => {
    try {
      const r1 = await fetch(`${PYTHON_BACKEND}/api/memory/pending-review/${encodeURIComponent(req.params.id)}/reject`, { method: 'POST' })
      res.status(r1.status).json(await r1.json())
    } catch (e) {
      res.status(503).json({ error: 'python backend unavailable', detail: e.message })
    }
  })

  r.post('/memory/pending-review/:id/edit', requireAuth, async (req, res) => {
    try {
      const r1 = await fetch(`${PYTHON_BACKEND}/api/memory/pending-review/${encodeURIComponent(req.params.id)}/edit`, {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify(req.body || {}),
      })
      res.status(r1.status).json(await r1.json())
    } catch (e) {
      res.status(503).json({ error: 'python backend unavailable', detail: e.message })
    }
  })

  return r
}
