  r.get('/agents/:id/prompt', requireAuth, (req, res) => {
    const data = readJSON(path.join(STATE_DIR, 'agent_prompts', `${req.params.id}.json`), { prompt: '', versions: [] })
    res.json({ prompt: data.prompt || '', versions: data.versions || [] })
  })

  r.put('/agents/:id/prompt', requireAuth, (req, res) => {
    const { prompt } = req.body || {}
    if (typeof prompt !== 'string') return res.status(400).json({ error: 'prompt required' })
    const file = path.join(STATE_DIR, 'agent_prompts', `${req.params.id}.json`)
    const data = readJSON(file, { prompt: '', versions: [] })
    const versions = data.versions || []
    if (data.prompt) versions.unshift({ prompt: data.prompt, saved_at: new Date().toISOString() })
    data.versions = versions.slice(0, 5)
    data.prompt = prompt
    writeJSON(file, data)
    res.json({ ok: true })
  })

  r.get('/agents/:id/prompt/history', requireAuth, (req, res) => {
    const data = readJSON(path.join(STATE_DIR, 'agent_prompts', `${req.params.id}.json`), { versions: [] })
    res.json({ versions: data.versions || [] })
  })

  // ── SECURITY — API KEYS ───────────────────────────────────────────────────

  r.get('/security/api-keys', requireAuth, (req, res) => {
    const { keys = [] } = readJSON(path.join(STATE_DIR, 'api_keys.json'), { keys: [] })
    res.json({ keys: keys.map(k => ({ ...k, key: k.key.slice(0, 8) + '...' })) })
  })

  r.post('/security/api-keys', requireAuth, (req, res) => {
    const { name, scopes = [], expiry_days = 90 } = req.body || {}
    if (!name) return res.status(400).json({ error: 'name required' })
    const file  = path.join(STATE_DIR, 'api_keys.json')
    const store = readJSON(file, { keys: [] })
    const key   = crypto.randomBytes(32).toString('hex')
    const entry = {
      id:         `ak_${Date.now()}`,
      name,
      scopes,
      key,
      created_at: new Date().toISOString(),
      expires_at: new Date(Date.now() + expiry_days * 86400000).toISOString(),
    }
    store.keys.push(entry)
    writeJSON(file, store)
    res.json({ ok: true, key })
  })

  r.post('/security/api-keys/:id/rotate', requireAuth, (req, res) => {
    const file  = path.join(STATE_DIR, 'api_keys.json')
    const store = readJSON(file, { keys: [] })
    const entry = store.keys.find(k => k.id === req.params.id)
    if (!entry) return res.status(404).json({ error: 'not found' })
    const newKey  = crypto.randomBytes(32).toString('hex')
    entry.key        = newKey
    entry.rotated_at = new Date().toISOString()
    writeJSON(file, store)
    res.json({ ok: true, key: newKey })
  })

  r.delete('/security/api-keys/:id', requireAuth, (req, res) => {
    const file  = path.join(STATE_DIR, 'api_keys.json')
    const store = readJSON(file, { keys: [] })
    store.keys  = store.keys.filter(k => k.id !== req.params.id)
    writeJSON(file, store)
    res.json({ ok: true })
  })

