    if (!topic) return res.status(400).json({ error: 'topic required' })
    const file   = path.join(STATE_DIR, 'scheduled_research.json')
    const topics = readJSON(file, [])
    const entry  = { id: `sr_${Date.now()}`, topic, frequency, notify, created_at: new Date().toISOString(), last_run: null, next_run: new Date(Date.now() + 86400000).toISOString() }
    topics.push(entry)
    writeJSON(file, topics)
    res.json({ ok: true, topic: entry })
