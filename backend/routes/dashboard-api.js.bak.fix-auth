    { id: 'zendesk',         name: 'Zendesk',         category: 'support', icon: '🎫' },
  ]

  r.get('/integrations', (req, res) => {
    const states = readJSON(path.join(STATE_DIR, 'integration_states.json'), {})
    const list = INTEG_CATALOG.map(i => ({
      ...i,
      connected: states[i.id]?.connected || false,
      last_sync: states[i.id]?.last_sync || null,
      error: states[i.id]?.error || null,
    }))
    res.json(list)
  })

  r.get('/integrations/list', (req, res) => {
    const states = readJSON(path.join(STATE_DIR, 'integration_states.json'), {})
    const list = INTEG_CATALOG.map(i => ({ ...i, connected: states[i.id]?.connected || false }))
    res.json({ integrations: list })
  })

  r.get('/integrations/activity', (req, res) => {
    res.json(readJSON(path.join(STATE_DIR, 'integration_activity.json'), []))
  })

  r.get('/integrations/:id', (req, res) => {
    const states = readJSON(path.join(STATE_DIR, 'integration_states.json'), {})
    const integ  = INTEG_CATALOG.find(i => i.id === req.params.id)
    if (!integ) return res.status(404).json({ error: 'not found' })
    res.json({ ...integ, ...states[req.params.id] })
  })

  r.post('/integrations/:id/connect', requireAuth, (req, res) => {
    const { type, api_key } = req.body || {}
    const file   = path.join(STATE_DIR, 'integration_states.json')
    const states = readJSON(file, {})
    if (type === 'apikey' && api_key) {
      states[req.params.id] = { connected: true, last_sync: new Date().toISOString(), type: 'apikey' }
      writeJSON(file, states)
      return res.json({ ok: true })
    }
    // OAuth: return a stub oauth_url (real impl would build provider URL)
    res.json({ oauth_url: null, ok: true, message: 'OAuth not configured — API key connection only' })
  })

  r.delete('/integrations/:id', requireAuth, (req, res) => {
    const file   = path.join(STATE_DIR, 'integration_states.json')
    const states = readJSON(file, {})
    delete states[req.params.id]
    writeJSON(file, states)
    res.json({ ok: true })
  })

  r.post('/integrations/:id/test', requireAuth, (req, res) => {
    const states = readJSON(path.join(STATE_DIR, 'integration_states.json'), {})
    const connected = states[req.params.id]?.connected
    res.json({ ok: connected, latency_ms: connected ? Math.floor(Math.random() * 200 + 50) : null, error: connected ? null : 'Not connected' })
  })

