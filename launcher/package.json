{
  "name": "ai-employee-launcher",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --linux AppImage deb"
  },
  "devDependencies": {
    "electron": "^39.8.5",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.ai-employee.launcher",
    "productName": "AI Employee",
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "assets/icon.png",
      "category": "Utility"
    },
    "extraResources": [
      {
        "from": "../",
        "to": "repo",
        "filter": [
          "start.sh",
          "stop.sh"
        ]
      }
    ]
  }
}
