.env
.ai-employee/
.openclaw/
*.log
logs/
.DS_Store
node_modules/
frontend/dist/
launcher/dist/
tmp/
temp/
*.tmp
*~
*.swp
*.bak
__pycache__/
*.pyc
*.pyo

# Security local overrides (openclaw-2) — never commit these
security.local.yml
config.local.yml
data/
models/
# but the neural-brain model-routing *source* lives under a models/ dir — keep it tracked
!runtime/neural_brain/models/
!runtime/neural_brain/models/**
runtime/neural_brain/models/**/__pycache__/
# and the frontend pages/models/ sub-directory is source code, not model weights
!frontend/src/components/pages/models/
!frontend/src/components/pages/models/**
venv/
.venv/

# Certificate / key files — never commit private keys
*.pem
*.key
*.crt
*.p12
*.pfx

# Runtime secrets — never commit live state/user data
state/users.json
state/brain_weights.json
state/learning_engine.json
state/version.json
.data/

# Test coverage artifacts
.coverage
coverage/
.pytest_cache/
backend.pid
python-backend.pid
worker.pid

# Runtime databases, event logs, and local telemetry are generated state.
state/*.db
state/*.db-*
state/*.jsonl
state/telemetry/
runtime/agents/problem-solver-ui/state/
runtime/wheelhouse/*/*.whl
runtime/wheelhouse/*/*.zip
runtime/wheelhouse/*/*.tar.gz
runtime/wheelhouse/*/manifest.json
runtime/browsers/playwright/**
!runtime/browsers/playwright/README.md
.build/

# Build output & vendored binaries — never source, huge.
src-tauri/target/
.claude/worktrees/
.claude/scheduled_tasks.lock
runtime/vendor/ollama/
ascend-ai-archived/backend/state/
state/codex_cache/
state/agents.json

# Test results (generated by run_full_tests.py)
test_results/screenshots/*.png
test_results/failures/*.png
test_results/failures/*.log
test_results/logs.txt
test_results/system_report.json

# ASCEND AI build output
ascend-ai/backend/static/
ascend-ai/frontend/node_modules/

# Generated runtime state — these are produced at runtime, never source.
state/artifacts/
runtime/state/
state/code_index/
state/generated_images/
state/research_screenshots/
state/boot_metrics.json
state/*.pre-chroma
# Runtime stores — generated at runtime in the canonical state dir (C0), never source.
state/knowledge_store.json
state/memory_index.json
state/model-registry.json
state/model_benchmarks.json
state/research_budget.json
state/security_sync_queue.json
state/security_sync_history.log
state/tasks.json
state/vector_store.json
.claude/scheduled_tasks.lock

# Local voice-core bundle payloads are downloaded/generated, not source.
resources/voice-core/.cache/
resources/voice-core/models/
resources/voice-core/runtimes/
resources/voice-core/samples/*.wav
resources/voice-core/licenses/
!resources/voice-core/README.md
!resources/voice-core/manifest.json
