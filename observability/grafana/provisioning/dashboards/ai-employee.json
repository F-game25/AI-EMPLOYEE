{
  "__inputs": [],
  "__requires": [
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "datasource", "id": "loki",       "name": "Loki",       "version": "1.0.0" },
    { "type": "panel",      "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel",      "id": "stat",       "name": "Stat",        "version": "" }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "AI-Employee — Node.js + Python FastAPI observability",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "API Request Rate (req/s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "ae-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "gradientMode": "none",
            "showPoints": "never",
            "spanNulls": false
          },
          "unit": "reqps",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red",    "value": 200 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "max", "last"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "ae-prometheus" },
          "expr": "rate(ai_employee_api_calls_total[5m])",
          "legendFormat": "API calls/s — {{service}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "ae-prometheus" },
          "expr": "rate(ai_employee_tasks_total[5m])",
          "legendFormat": "Tasks/s — {{service}}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 2,
      "title": "Error Rate (errors/s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "ae-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "red" },
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 40,
            "showPoints": "never",
            "spanNulls": false
          },
          "unit": "reqps",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red",    "value": 0.1  }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Task failure rate" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }]
          }
        ]
      },
      "options": {
        "legend": { "calcs": ["mean", "max", "last"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "ae-prometheus" },
          "expr": "rate(ai_employee_errors_total[5m])",
          "legendFormat": "Error rate — {{service}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "ae-prometheus" },
          "expr": "rate(ai_employee_tasks_failed_total[5m])",
          "legendFormat": "Task failure rate — {{service}}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 3,
      "title": "Uptime (ms)",
      "description": "Process uptime in milliseconds — proxy for P95 latency until histogram metrics are instrumented. Replace expr with histogram_quantile(0.95, ...) when available.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "ae-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 8,
            "showPoints": "never",
            "spanNulls": false
          },
          "unit": "ms",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["last"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "ae-prometheus" },
          "expr": "ai_employee_uptime_ms",
          "legendFormat": "Uptime ms — {{service}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Active Agents",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "ae-prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "short",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 30   },
              { "color": "red",    "value": 56   }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "ae-prometheus" },
          "expr": "ai_employee_agents_active",
          "legendFormat": "Active agents",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 5,
      "title": "Cost per Day (from Telemetry Logs)",
      "description": "Counts LLM cost events from telemetry JSONL ingested via Loki. Requires cost entries with event_type='llm_cost' and a numeric 'cost_usd' field in the log line.",
      "type": "stat",
      "datasource": { "type": "loki", "uid": "ae-loki" },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "currencyUSD",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 5    },
              { "color": "red",    "value": 20   }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "ae-loki" },
          "expr": "sum_over_time({job=\"telemetry\"} | json | event_type=`llm_cost` | unwrap cost_usd [1d])",
          "legendFormat": "LLM cost today",
          "refId": "A",
          "queryType": "instant"
        }
      ]
    },
    {
      "id": 6,
      "title": "Task Completion Ratio",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "ae-prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 0.8  },
              { "color": "green",  "value": 0.95 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "ae-prometheus" },
          "expr": "ai_employee_tasks_completed_total / clamp_min(ai_employee_tasks_total, 1)",
          "legendFormat": "Completion ratio",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 7,
      "title": "Recent Log Errors",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "ae-loki" },
      "gridPos": { "h": 10, "w": 18, "x": 6, "y": 16 },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "ae-loki" },
          "expr": "{job=\"ai-employee\"} | json | level=~\"error|ERROR|critical|CRITICAL\"",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["ai-employee", "observability"],
  "templating": {
    "list": [
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "ae-prometheus" },
        "definition": "label_values(ai_employee_agents_active, service)",
        "hide": 0,
        "includeAll": true,
        "label": "Service",
        "multi": false,
        "name": "service",
        "options": [],
        "query": { "query": "label_values(ai_employee_agents_active, service)", "refId": "StandardVariableQuery" },
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "AI-Employee Overview",
  "uid": "ai-employee-overview",
  "version": 1,
  "weekStart": ""
}
